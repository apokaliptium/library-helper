{
  "name": "@apokaliptium/library-helper",
  "description": "smartcontract toolset for omnilibris universal library repositorial system handling, managing, building and using. just some misc bag of procedures, that's all.",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "apokaliptium",
    "url": "https://github.com/apokaliptium"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.3.0"
  },
  "devDependencies": {
    "forge-std": "github:foundry-rs/forge-std#v1.9.7",
    "prettier": "^3.5",
    "solhint": "^5.1"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "forge",
    "foundry",
    "smart-contracts",
    "solidity",
    "template"
  ],
  "scripts": {
    "clean": "rm -rf cache out",
    "build": "forge build",
    "forge-check": "forge fmt --check",
    "forge-write": "forge fmt",
    "full-check": "bun run forge-check && bun run solhint-check && bun run prettier:check",
    "full-write": "bun run forge-write && bun run prettier:write",
    "prettier:check": "prettier --check \"**/*.{json,md,yml}\"",
    "prettier:write": "prettier --write \"**/*.{json,md,yml}\"",
    "solhint-check": "bun solhint \"{script,src,tests}/**/*.sol\"",
    "test": "forge test"
  }
}
